# Build outputs
.gradle/
build/
out/
**/*.class
**/*.jar
# Gradle's wrapper JAR is required for `./gradlew` to bootstrap — must
# be tracked even though it matches the *.jar pattern above.
!**/gradle/wrapper/gradle-wrapper.jar

# IDE / editor
.idea/
*.iml
.vscode/
.fleet/
.claude/
# IntelliJ Platform Gradle plugin's working dir (downloaded IDE
# artifacts, sandbox, self-update lock). All caches and generated.
.intellijPlatform/

# OS
.DS_Store
Thumbs.db

# Logs and ephemeral state
*.log
state/
